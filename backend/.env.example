DATABASE_URL=sqlite:///./app.db
SECRET_KEY=your-super-secret-key-goes-here
ALGORITHM=HS256

# Serve /docs, /redoc and /openapi.json (v0.1.10). On here because this
# file is the documented development setup (`cp .env.example .env`); the
# code default is OFF, so a deployment that configures nothing gets no
# public map of its own API -- admin endpoints included.
ENABLE_API_DOCS=true

# Access tokens are short-lived on purpose; sessions stay alive via
# refresh tokens instead (see backend/README.md's security section).
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# How long a just-rotated refresh token keeps working (v0.1.8). Covers two
# browser tabs refreshing at once, and clients retrying after a lost
# response -- without it, either one looks like a stolen token being
# replayed and destroys every session the user has. Only applies to tokens
# revoked BY ROTATION: logout, logout-all and password reset always bite
# immediately. Seconds, not minutes -- a thief replaying inside this window
# isn't detected.
REFRESH_REUSE_GRACE_SECONDS=10

# true: mock translation service that runs without downloading a model (default)
# false: real NLLB transformer model (transformers + torch must be installed)
USE_MOCK_TRANSLATION=true
TRANSLATION_MODEL_NAME=facebook/nllb-200-distilled-600M

# Optional: leave SMTP_HOST empty to use the mock email service (emails are
# recorded, not sent -- fine for development/testing). Fill these in to send
# real verification/password-reset emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@lingua.example

# Used to build links inside verification/reset emails (e.g. .../verify-email?token=...)
FRONTEND_BASE_URL=http://localhost:5173

# Redis translation cache (v0.1.0) -- leave empty to disable (default).
# docker-compose sets this to redis://redis:6379/0 automatically.
REDIS_URL=
TRANSLATION_CACHE_TTL_SECONDS=604800

# Rate-limit budgets (v0.1.2) -- raise ONLY for capacity testing.
API_RATE_LIMIT_PER_MINUTE=120
TRANSLATE_RATE_LIMIT_PER_MINUTE=30

# Failed logins allowed from one address per minute, across every username
# it tries (v0.1.6) -- the cap on password spraying. Successful logins are
# never charged, so a busy shared address (office NAT, mobile CGNAT) does
# not accumulate a budget just by being used. Raise it only if genuinely
# *failed* logins from one shared address trip it.
LOGIN_IP_FAILURE_LIMIT_PER_MINUTE=20

# How many reverse proxies YOU control sit in front of the app (v0.1.4).
# 0 (default) = none: the socket address is the client. Correct for local
# dev and docker-compose. Behind Railway/Render/Fly set 1; add 1 more for
# a CDN in front of that. Rate limiting keys on the address this resolves,
# so too high means per-IP limits can be bypassed with a forged
# X-Forwarded-For -- see DEPLOYMENT.md before changing it.
TRUSTED_PROXY_HOPS=0

# CORS allowlist (comma-separated). Empty = development defaults, which
# cover both http://localhost:5173 and http://127.0.0.1:5173 (different
# origins to a browser). Set this explicitly in any deployment.
CORS_ALLOWED_ORIGINS=

# Bump to invalidate every cached translation at once.
TRANSLATION_CACHE_VERSION=1
